{
  "name": "@specodec/typespec-emitter-swift",
  "version": "1.0.7",
  "type": "module",
  "main": "dist/index.js",
  "typespec": {
    "emitter": true,
    "options": {
      "@specodec/typespec-emitter-swift": {
        "type": "object",
        "properties": {
          "emitter-output-dir": {
            "type": "string"
          },
          "ignore-reserved-keywords": {
            "type": "boolean"
          }
        },
        "required": [
          "emitter-output-dir"
        ]
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@typespec/compiler": "^1.12.0",
    "typescript": "^5.8.0",
    "@specodec/typespec-emitter-core": "^1.0.0"
  },
  "publishConfig": {
    "registry": "http://10.199.64.20:3000/api/packages/specodec/npm/"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.12.0",
    "@specodec/typespec-emitter-core": "^1.0.0"
  }
}
