{
  "name": "@specodec/typespec-specodec-swift",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "typespec": {
    "emitter": true,
    "options": {
      "@specodec/typespec-specodec-swift": {
        "type": "object",
        "properties": {
          "emitter-output-dir": { "type": "string" },
          "ignore-reserved-keywords": { "type": "boolean" }
        },
        "required": ["emitter-output-dir"]
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@specodec/typespec-specodec-core": "file:/tmp/specodec-typespec-specodec-core-0.0.1.tgz"
  },
  "devDependencies": {
    "@typespec/compiler": "1.11.0",
    "typescript": "^5.8.0"
  }
}